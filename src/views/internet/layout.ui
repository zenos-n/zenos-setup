<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0" />
  <template class="ZenOSDefaultNetwork" parent="AdwBin">
    <property name="hexpand">true</property>
    <property name="vexpand">true</property>
    <child>
      <object class="GtkStack" id="main_stack">
        <property name="transition-type">crossfade</property>
        
        <!-- Checking Connection State -->
        <child>
          <object class="GtkStackPage">
            <property name="name">checking</property>
            <property name="child">
              <object class="AdwStatusPage" id="checking_page">
                <property name="icon-name">content-loading-symbolic</property>
                <property name="title" translatable="yes">Checking Connection</property>
                <property name="description" translatable="yes">Please wait until the connection check is done</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkSpinner" id="loading_spinner">
                        <property name="width-request">32</property>
                        <property name="height-request">32</property>
                        <property name="halign">center</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_recheck">
                        <property name="label" translatable="yes">Check Again</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="pill" />
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <!-- Network Selection State -->
        <child>
          <object class="GtkStackPage">
            <property name="name">network</property>
            <property name="child">
              <object class="GtkOverlay">
                <property name="valign">center</property>
                <child type="overlay">
                  <object class="GtkButton" id="btn_next">
                    <property name="sensitive">false</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="icon-name">go-next-symbolic</property>
                    <property name="halign">end</property>
                    <property name="valign">center</property>
                    <property name="tooltip-text" translatable="yes">Next</property>
                    <style>
                      <class name="circular" />
                      <class name="suggested-action" />
                    </style>
                  </object>
                </child>
                <child>
                  <object class="AdwStatusPage" id="status_page">
                    <property name="title" translatable="yes">Internet</property>
                    <property name="description" translatable="yes">An active internet connection is required to install the system</property>
                    <property name="icon-name">network-wireless-symbolic</property>
                    <child>
                      <object class="AdwClamp">
                        <property name="maximum-size">600</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="hexpand">false</property>
                            <child>
                              <object class="AdwPreferencesGroup" id="wired_group">
                                <property name="title" translatable="yes">Wired</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwPreferencesGroup" id="wireless_group">
                                <property name="title" translatable="yes">Wireless Networks</property>
                                <child>
                                  <object class="AdwPreferencesRow" id="network_spinner_row">
                                    <property name="activatable">false</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="halign">center</property>
                                        <property name="hexpand">true</property>
                                        <property name="margin-top">12</property>
                                        <property name="margin-bottom">12</property>
                                        <child>
                                          <object class="GtkSpinner" id="network_spinner">
                                            <property name="width-request">24</property>
                                            <property name="height-request">24</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwPreferencesGroup" id="advanced_group">
                                <property name="title" translatable="yes">Advanced</property>
                                <child>
                                  <object class="AdwActionRow" id="hidden_network_row">
                                    <property name="title" translatable="yes">Connect to Hidden Network...</property>
                                    <child type="prefix">
                                      <object class="GtkOverlay">
                                        <property name="vexpand">false</property>
                                        <property name="hexpand">false</property>
                                        <property name="margin-end">10</property>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">network-wireless-signal-none-symbolic</property>
                                          </object>
                                        </child>
                                        <child type="overlay">
                                          <object class="GtkImage">
                                            <property name="valign">end</property>
                                            <property name="halign">start</property>
                                            <property name="margin-start">10</property>
                                            <property name="margin-bottom">10</property>
                                            <property name="icon-name">background-app-ghost-symbolic</property>
                                            <property name="pixel-size">14</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="AdwActionRow" id="proxy_settings_row">
                                    <property name="title" translatable="yes">Open Proxy Settings...</property>
                                    <child type="prefix">
                                      <object class="GtkImage">
                                        <property name="margin-start">5</property>
                                        <property name="margin-end">5</property>
                                        <property name="icon-name">preferences-system-network-proxy-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

      </object>
    </child>
  </template>
</interface>
