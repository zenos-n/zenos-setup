<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="ZenOSDefaultTimezone" parent="AdwBin">
    <property name="hexpand">true</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">1</property>
        <property name="vexpand">true</property>
        <property name="hexpand">true</property>
        <property name="valign">0</property>
        <property name="halign">0</property>
        <child>
          <object class="GtkOverlay">
            <property name="valign">3</property>
            <property name="halign">0</property>
            <property name="hexpand">true</property>
            <child>
              <object class="AdwStatusPage" id="status_page">
                <property name="valign">0</property>
                <property name="vexpand">true</property>
                <property name="icon-name">preferences-system-time-symbolic</property>
                <property name="title" translatable="yes">Date &amp; Time</property>
                <property name="description" translatable="yes">Select your preferred timezone</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">600</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">1</property>
                        <child>
                          <object class="GtkSearchEntry" id="entry_search_timezone">
                            <property name="hexpand">true</property>
                            <property name="placeholder-text" translatable="yes">Search timezones</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSpinner" id="loading_spinner">
                            <property name="spinning">true</property>
                            <property name="width-request">32</property>
                            <property name="height-request">32</property>
                            <property name="margin-top">32</property>
                            <property name="margin-bottom">32</property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup" id="all_timezones_group"></object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkStack">
            <property name="vhomogeneous">false</property>
            <child>
              <object class="GtkStackPage">
                <property name="name">current_tz_footer</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">1</property>
                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">0</property>
                        <property name="halign">3</property>
                        <property name="spacing">10</property>
                        <property name="margin-top">10</property>
                        <property name="margin-bottom">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Current timezone: </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="current_tz_label">
                            <style>
                              <class name="heading"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="current_location_label"></object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
