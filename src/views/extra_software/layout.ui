<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="ZenOSLayoutApplications" parent="AdwBin">
    <property name="hexpand">true</property>
    <property name="vexpand">true</property>
    <child>
      <object class="GtkOverlay">
        <property name="valign">3</property>
        <child>
          <object class="AdwStatusPage">
            <property name="halign">0</property>
            <property name="valign">0</property>
            <property name="hexpand">true</property>
            <property name="title" translatable="yes">Applications</property>
            <property name="description" translatable="yes">Choose which applications to install.</property>
            <property name="icon-name">org.gnome.Software-symbolic</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">1</property>
                <property name="vexpand">true</property>
                <property name="hexpand">true</property>
                <property name="valign">3</property>
                <child>
                  <object class="AdwPreferencesPage">
                    <child>
                      <object class="AdwPreferencesGroup" id="bundles_list">
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Core Applications</property>
                            <property name="subtitle" translatable="yes">Essential apps like Calendar or Document Viewer</property>
                            <property name="activatable-widget">core_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="core_check">
                                <property name="active">true</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="core_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">true</property>
                                <property name="tooltip-text" translatable="yes">Customize Core Applications</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Browsers</property>
                            <property name="subtitle" translatable="yes">Web browser for your desktop</property>
                            <property name="activatable-widget">browsers_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="browsers_switch">
                                <property name="active">true</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="browsers_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">true</property>
                                <property name="tooltip-text" translatable="yes">Customize Browsers</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Common Utilities</property>
                            <property name="subtitle" translatable="yes">Useful utilities to enhance your desktop experience</property>
                            <property name="activatable-widget">utilities_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="utilities_switch">
                                <property name="valign">3</property>
                                <property name="active">true</property>
                                <property name="focusable">false</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="utilities_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">true</property>
                                <property name="tooltip-text" translatable="yes">Customize Utilities</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Gaming</property>
                            <property name="subtitle" translatable="yes">Steam, emulators and tools for video games</property>
                            <property name="activatable-widget">gaming_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="gaming_switch">
                                <property name="valign">3</property>
                                <property name="active">false</property>
                                <property name="focusable">false</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="gaming_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">true</property>
                                <property name="tooltip-text" translatable="yes">Customize Gaming Apps</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Development Tools</property>
                            <property name="subtitle" translatable="yes">Code editors and other useful tools for developers</property>
                            <property name="activatable-widget">dev_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="dev_switch">
                                <property name="valign">3</property>
                                <property name="active">false</property>
                                <property name="focusable">false</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="dev_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">true</property>
                                <property name="tooltip-text" translatable="yes">Customize Dev Apps</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Office</property>
                            <property name="subtitle" translatable="yes">The LibreOffice suite</property>
                            <property name="activatable-widget">office_button</property>
                            <child type="prefix">
                              <object class="GtkCheckButton" id="office_switch">
                                <property name="valign">3</property>
                                <property name="active">false</property>
                                <property name="focusable">false</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="office_button">
                                <property name="valign">3</property>
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="sensitive">false</property>
                                <property name="tooltip-text" translatable="yes">Customize Office Applications</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
