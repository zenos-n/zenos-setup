<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="ZenOSTheme" parent="AdwBin">
    <property name="hexpand">true</property>
    <property name="vexpand">true</property>
    <child>
      <object class="GtkOverlay">
        <property name="valign">3</property>
        <child>
          <object class="AdwStatusPage">
            <property name="title" translatable="yes">Color Scheme</property>
            <property name="description" translatable="yes">Choose a color scheme for your system</property>
            <property name="icon-name">dark-mode-symbolic</property>
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">500</property>
                <property name="tightening-threshold">400</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">1</property>
                    <property name="spacing">24</property>
                    <child>
                      <object class="AdwPreferencesGroup">
                        <child>
                          <object class="AdwPreferencesRow">
                            <property name="activatable">false</property>
                            <property name="focusable">false</property>
                            <child>
                              <object class="AdwClamp">
                                <property name="maximum-size">400</property>
                                <property name="tightening-threshold">300</property>
                                <child>
                                  <object class="GtkGrid">
                                    <property name="column-homogeneous">true</property>
                                    <property name="column-spacing">24</property>
                                    <property name="row-spacing">12</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <property name="margin-top">18</property>
                                    <property name="margin-bottom">12</property>
                                    <property name="hexpand">true</property>
                                    <child>
                                      <object class="GtkToggleButton" id="btn_default">
                                        <property name="tooltip-text" translatable="yes">Light Mode</property>
                                        <child>
                                          <object class="GtkOverlay">
                                            <child>
                                              <object class="GtkPicture" id="default_image">
                                                <property name="hexpand">true</property>
                                                <property name="halign">3</property>
                                                <property name="can-shrink">false</property>
                                                <style>
                                                  <class name="appearance-thumbnail"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child type="overlay">
                                              <object class="GtkPicture">
                                                <property name="hexpand">true</property>
                                                <property name="halign">3</property>
                                                <property name="can-shrink">false</property>
                                                <style>
                                                  <class name="appearance-thumbnail"/>
                                                  <class name="icon-dropshadow"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <style>
                                          <class name="background-preview-button"/>
                                        </style>
                                        <layout>
                                          <property name="column">0</property>
                                          <property name="row">0</property>
                                        </layout>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="default_label">
                                        <property name="label" translatable="yes">Light</property>
                                        <layout>
                                          <property name="column">0</property>
                                          <property name="row">1</property>
                                        </layout>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkToggleButton" id="btn_dark">
                                        <property name="tooltip-text" translatable="yes">Dark Mode</property>
                                        <property name="group">btn_default</property>
                                        <child>
                                          <object class="GtkOverlay">
                                            <child>
                                              <object class="GtkPicture" id="dark_image">
                                                <property name="hexpand">true</property>
                                                <property name="halign">3</property>
                                                <property name="can-shrink">false</property>
                                                <style>
                                                  <class name="appearance-thumbnail"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child type="overlay">
                                              <object class="GtkPicture">
                                                <property name="hexpand">true</property>
                                                <property name="halign">3</property>
                                                <property name="can-shrink">false</property>
                                                <style>
                                                  <class name="appearance-thumbnail"/>
                                                  <class name="icon-dropshadow"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <style>
                                          <class name="background-preview-button"/>
                                        </style>
                                        <layout>
                                          <property name="column">1</property>
                                          <property name="row">0</property>
                                        </layout>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="dark_label">
                                        <property name="label" translatable="yes">Dark</property>
                                        <layout>
                                          <property name="column">1</property>
                                          <property name="row">1</property>
                                        </layout>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="title" translatable="yes">Accent Color</property>
                        <child>
                          <object class="AdwPreferencesRow">
                            <property name="activatable">false</property>
                            <property name="focusable">false</property>
                            <child>
                              <object class="GtkBox" id="accent_box">
                                <property name="halign">3</property>
                                <property name="margin-top">14</property>
                                <property name="margin-bottom">14</property>
                                <property name="spacing">12</property>
                                <child>
                                  <object class="GtkToggleButton" id="accent_blue">
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Blue</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-blue"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_teal">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Teal</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-teal"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_green">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Green</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-green"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_yellow">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Yellow</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-yellow"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_orange">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Orange</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-orange"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_red">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Red</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-red"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_pink">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Pink</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-pink"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_purple">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Purple</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-purple"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="accent_slate">
                                    <property name="group">accent_blue</property>
                                    <property name="width-request">36</property>
                                    <property name="height-request">36</property>
                                    <property name="valign">3</property>
                                    <property name="halign">3</property>
                                    <property name="tooltip-text" translatable="yes">Slate</property>
                                    <style>
                                      <class name="circular"/>
                                      <class name="color-button"/>
                                      <class name="accent-slate"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
